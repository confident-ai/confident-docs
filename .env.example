# Screenshot automation config. Copy to .env and fill in. See screenshots/README.md.
# capture.py auto-loads .env; real environment variables always win (so CI is unaffected).

# Required
PLATFORM_BASE_URL=https://app.confident-ai.com
CONFIDENT_PROJECT_ID=
S3_BUCKET=confident-docs

# Required when a path uses :aiConnectionId
CONFIDENT_AI_CONNECTION_ID=

# Required when a path uses :annotationFormId (the form editor shots)
CONFIDENT_ANNOTATION_FORM_ID=

# Required only to publish (omit for DRY_RUN previews)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Optional
SHOTSCRAPER_AUTH_FILE=auth.json
ONLY_PATH_PREFIX=/project/:projectId/project-settings/ai-connections
OUT_DIR=_shots
# DRY_RUN=1
